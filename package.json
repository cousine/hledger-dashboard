{
  "name": "hledger-dashboard",
  "version": "1.0.0",
  "description": "Obsidian plugin: financial dashboard for hledger journals",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "toc": "doctoc --minlevel 2 --maxlevel 2 README.md",
    "toc:check": "doctoc --minlevel 2 --maxlevel 2 README.md --dryrun",
    "lint": "biome check --write src tests",
    "lint:check": "biome check src tests",
    "lint:obsidian": "eslint src",
    "lint:obsidian:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "version:check": "node scripts/check-versions.mjs"
  },
  "keywords": [
    "obsidian",
    "hledger",
    "finance",
    "accounting",
    "dashboard",
    "plaintext-accounting"
  ],
  "author": "cousine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cousine/hledger-dashboard.git"
  },
  "homepage": "https://github.com/cousine/hledger-dashboard#readme",
  "bugs": {
    "url": "https://github.com/cousine/hledger-dashboard/issues"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=26.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "0.14.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "chart.js": "^4.4.0",
    "chartjs-chart-treemap": "^2.0.0",
    "doctoc": "^2.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "happy-dom": "^20.10.6",
    "obsidian": "1.11.4",
    "tslib": "^2.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
